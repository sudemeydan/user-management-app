generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id              Int              @id @default(autoincrement())
  email           String           @unique
  password        String
  name            String?
  username        String           @unique
  age             Int?
  address         String?
  role            String           @default("FREE_USER")
  createdAt       DateTime         @default(now())
  profileImage    ProfileImage?
  
  upgradeRequests UpgradeRequest[] 
  profile         Profile?         
  tasks           Task[]          
  isPrivate           Boolean       @default(false)
  sentConnections     Connection[]  @relation("SentConnections")
  receivedConnections Connection[]  @relation("ReceivedConnections")
  posts               Post[]
  blockingUsers       Block[]       @relation("BlockingUser")
  blockedUsers        Block[]       @relation("BlockedUser")
}

model Block {
  id        Int      @id @default(autoincrement())
  blockerId Int
  blocker   User     @relation("BlockingUser", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId Int
  blocked   User     @relation("BlockedUser", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model UpgradeRequest {
  id        Int      @id @default(autoincrement())
  status    String   @default("PENDING") 
  adminNote String?  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt          

  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

model Profile {
  id      Int     @id @default(autoincrement())
  bio     String?
  phone   String?
  userId  Int     @unique
  user    User    @relation(fields: [userId], references: [id])
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  isCompleted Boolean  @default(false)
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}

model ProfileImage {
  id        Int      @id @default(autoincrement())
  
  url       String   
  
  fileId    String   
  
  userId    Int      @unique 
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Connection {
  id         Int      @id @default(autoincrement())
  senderId   Int
  sender     User     @relation("SentConnections", fields: [senderId], references: [id])
  receiverId Int
  receiver   User     @relation("ReceivedConnections", fields: [receiverId], references: [id])
  status     String   @default("PENDING") // Durumlar: PENDING, ACCEPTED, REJECTED
  createdAt  DateTime @default(now())

  // Bir kişi aynı kişiye sadece 1 istek atabilsin diye veritabanı düzeyinde koruma:
  @@unique([senderId, receiverId]) 
}

// Eski halini güncelliyoruz:
model Post {
  id        Int         @id @default(autoincrement())
  content   String?     // Kullanıcının yazdığı metin
  authorId  Int
  author    User        @relation(fields: [authorId], references: [id])
  images    PostImage[] // YENİ: Bir gönderinin birden fazla resmi olabilir
  createdAt DateTime    @default(now())
}

model PostImage {
  id        Int      @id @default(autoincrement())
  url       String   // Ekranda göstermek için Drive Linki
  fileId    String   // Silme işlemi için Drive Dosya Kimliği (Kritik!)
  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
