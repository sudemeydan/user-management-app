generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id              Int              @id @default(autoincrement())
  email           String           @unique
  password        String
  name            String?
  username        String           @unique
  age             Int?
  address         String?
  role            String           @default("FREE_USER")
  createdAt       DateTime         @default(now())
  profileImage    ProfileImage?
  isEmailVerified          Boolean          @default(false)
  emailVerificationToken   String?          @unique
  resetPasswordToken       String?          @unique
  resetPasswordExpires     DateTime?
  cvs                CV[]
  
  upgradeRequests UpgradeRequest[] 
  profile         Profile?         
  tasks           Task[]          
  isPrivate           Boolean       @default(false)
  sentConnections     Connection[]  @relation("SentConnections")
  receivedConnections Connection[]  @relation("ReceivedConnections")
  posts               Post[]
  blockingUsers       Block[]       @relation("BlockingUser")
  blockedUsers        Block[]       @relation("BlockedUser")
  tailoredCVs         TailoredCV[]
}

model Block {
  id        Int      @id @default(autoincrement())
  blockerId Int
  blocker   User     @relation("BlockingUser", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId Int
  blocked   User     @relation("BlockedUser", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model UpgradeRequest {
  id        Int      @id @default(autoincrement())
  status    String   @default("PENDING") 
  adminNote String?  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt          

  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

model Profile {
  id      Int     @id @default(autoincrement())
  bio     String?
  phone   String?
  userId  Int     @unique
  user    User    @relation(fields: [userId], references: [id])
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  isCompleted Boolean  @default(false)
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}

model ProfileImage {
  id        Int      @id @default(autoincrement())
  
  url       String   
  
  fileId    String   
  
  userId    Int      @unique 
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Connection {
  id         Int      @id @default(autoincrement())
  senderId   Int
  sender     User     @relation("SentConnections", fields: [senderId], references: [id])
  receiverId Int
  receiver   User     @relation("ReceivedConnections", fields: [receiverId], references: [id])
  status     String   @default("PENDING") // Durumlar: PENDING, ACCEPTED, REJECTED
  createdAt  DateTime @default(now())

  // Bir kişi aynı kişiye sadece 1 istek atabilsin diye veritabanı düzeyinde koruma:
  @@unique([senderId, receiverId]) 
}

// Eski halini güncelliyoruz:
model Post {
  id        Int         @id @default(autoincrement())
  content   String?     // Kullanıcının yazdığı metin
  authorId  Int
  author    User        @relation(fields: [authorId], references: [id])
  images    PostImage[] // YENİ: Bir gönderinin birden fazla resmi olabilir
  createdAt DateTime    @default(now())
}

model PostImage {
  id        Int      @id @default(autoincrement())
  url       String   // Ekranda göstermek için Drive Linki
  fileId    String   // Silme işlemi için Drive Dosya Kimliği (Kritik!)
  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model CV {
  id           Int      @id @default(autoincrement())
  fileName     String   // Kullanıcının gördüğü orijinal dosya adı (örn: "Backend_Developer_Sude.pdf")
  fileId       String   // Google Drive'daki benzersiz dosya ID'si
  fileSize     Int      // Dosya boyutu (Byte cinsinden tutacağız, frontend'de MB/KB'a çevireceğiz)
  mimeType     String   // 'application/pdf' veya docx formatı tespiti için
  isActive     Boolean  @default(false) // Profilde sergilenecek ana CV mi?
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  status       JobStatus @default(PENDING) // Ayrıştırma durumunu takip etmek için
  rawText      String?   @db.Text          // Python'dan gelecek ham metin
  summary      String?   @db.Text          // Gemini'nin çıkaracağı özet
  entries      CVEntry[]                   // 1-N İlişkisi

  // YENİ: ATS Skoru ve Geri Bildirimi
  atsFormatScore    Int?
  atsFormatFeedback String? @db.Text

  atsFormattedCV AtsFormattedCV?
  tailoredCVs    TailoredCV[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}


model CVEntry {
  id          Int           @id @default(autoincrement())
  cvId        Int           // İlişki tipi senin projene uygun olarak Int yapıldı
  cv          CV            @relation(fields: [cvId], references: [id], onDelete: Cascade)
  
  category    EntryCategory 
  
  title       String        
  subtitle    String?       
  startDate   String?       
  endDate     String?       
  description String?       @db.Text 
  metadata    Json?         
  
  createdAt   DateTime      @default(now())
}

model AtsFormattedCV {
  id        Int      @id @default(autoincrement())
  cvId      Int      @unique
  cv        CV       @relation(fields: [cvId], references: [id], onDelete: Cascade)
  
  fileId    String?  // Üretilen ATS-Friendly PDF'in Drive ID'si
  content   Json?    // Formatlanmış veri (opsiyonel, entries'den de alınabilir)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobPosting {
  id              Int      @id @default(autoincrement())
  title           String
  company         String?
  description     String   @db.Text
  url             String?
  extractedSkills Json?    // Gemini tarafından çıkarılan anahtar kelimeler
  
  tailoredCVs     TailoredCV[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TailoredCV {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  jobPostingId    Int
  jobPosting      JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  
  originalCvId    Int
  originalCv      CV       @relation(fields: [originalCvId], references: [id], onDelete: Cascade)
  
  atsScore        Int?     // İlanla uyum skoru
  improvedSummary String?  @db.Text
  
  entries         TailoredCVEntry[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TailoredCVEntry {
  id            Int           @id @default(autoincrement())
  tailoredCvId  Int
  tailoredCv    TailoredCV    @relation(fields: [tailoredCvId], references: [id], onDelete: Cascade)
  
  category      EntryCategory
  name          String
  description   String?       @db.Text
  
  isModified    Boolean       @default(false)
  aiComment     String?       @db.Text
  
  createdAt     DateTime      @default(now())
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum EntryCategory {
  CONTACT_INFO
  EXPERIENCE
  EDUCATION
  SKILL
  PROJECT
  LANGUAGE
  CERTIFICATE
  OTHER
}
