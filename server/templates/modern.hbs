<!DOCTYPE html>
<html lang="{{lang}}">

<head>
    <meta charset="UTF-8">
    <title>{{name}} - CV</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@400;500;600;700;800&family=Open+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        @page { size: A4; margin: 0; }
        html, body {
            width: 210mm; min-height: 297mm;
            font-family: 'Open Sans', 'Segoe UI', Arial, sans-serif;
            font-size: 9pt; color: #2d3748; line-height: 1.45;
            -webkit-print-color-adjust: exact; print-color-adjust: exact; background: #fff;
        }
        a { color: inherit; text-decoration: none; }
        h1, h2, h3, h4, h5 { font-family: 'Raleway', 'Segoe UI', sans-serif; }

        .cv-container { display: flex; min-height: 297mm; width: 100%; }

        /* SIDEBAR */
        .sidebar {
            width: 72mm; background: linear-gradient(180deg, #1a202c 0%, #2d3748 100%);
            color: #e2e8f0; padding: 28px 18px 24px 18px; flex-shrink: 0;
        }
        .sidebar .avatar {
            width: 80px; height: 80px; border-radius: 50%;
            background: rgba(255,255,255,0.12); border: 3px solid rgba(255,255,255,0.25);
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 16px auto; font-family: 'Raleway', sans-serif;
            font-size: 26pt; font-weight: 700; color: #fff; letter-spacing: 1px;
        }
        .sidebar .sidebar-section { margin-bottom: 20px; }
        .sidebar .sidebar-title {
            font-family: 'Raleway', sans-serif; font-size: 8.5pt; font-weight: 700;
            text-transform: uppercase; letter-spacing: 1.8px; color: #90cdf4;
            border-bottom: 1px solid rgba(255,255,255,0.12); padding-bottom: 5px; margin-bottom: 10px;
        }
        .sidebar .contact-item {
            display: flex; align-items: flex-start; gap: 9px; margin-bottom: 7px;
            font-size: 8pt; line-height: 1.4; word-break: break-all;
        }
        .sidebar .contact-item i { color: #90cdf4; font-size: 9pt; width: 14px; text-align: center; margin-top: 1px; flex-shrink: 0; }
        .sidebar .contact-item a { color: #e2e8f0; text-decoration: none; }
        .skill-tags { display: flex; flex-wrap: wrap; gap: 5px; }
        .skill-tag {
            background: rgba(255,255,255,0.1); color: #e2e8f0; font-size: 7.5pt;
            padding: 3px 8px; border-radius: 3px; border: 1px solid rgba(255,255,255,0.08); font-weight: 500;
        }
        .lang-item { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; font-size: 8pt; }
        .lang-item .lang-name { font-weight: 600; color: #e2e8f0; }
        .lang-item .lang-level { font-size: 7.5pt; color: #90cdf4; font-weight: 500; }
        .cert-item { margin-bottom: 8px; font-size: 7.5pt; line-height: 1.35; }
        .cert-item .cert-name { font-weight: 600; color: #e2e8f0; font-size: 8pt; }
        .cert-item .cert-desc { color: #a0aec0; margin-top: 1px; }

        /* MAIN */
        .main-content { flex: 1; padding: 28px 26px 24px 26px; background: #fff; }
        .main-name { font-family: 'Raleway', sans-serif; font-size: 22pt; font-weight: 800; color: #1a202c; line-height: 1.1; margin-bottom: 2px; letter-spacing: -0.3px; }
        .main-subtitle { font-size: 9pt; color: #718096; font-weight: 500; margin-bottom: 16px; }

        .section-heading { display: flex; align-items: center; gap: 8px; margin-top: 18px; margin-bottom: 10px; page-break-after: avoid; }
        .section-heading .icon-circle { width: 22px; height: 22px; border-radius: 50%; background: #edf2f7; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .section-heading .icon-circle i { font-size: 9pt; color: #4a5568; }
        .section-heading h2 { font-family: 'Raleway', sans-serif; font-size: 11pt; font-weight: 700; color: #1a202c; text-transform: uppercase; letter-spacing: 1px; }
        .section-heading::after { content: ''; flex: 1; height: 1.5px; background: linear-gradient(90deg, #cbd5e0, transparent); }

        .summary-text { font-size: 8.5pt; color: #4a5568; line-height: 1.55; text-align: justify; }

        .entry { margin-bottom: 12px; page-break-inside: avoid; break-inside: avoid; }
        .entry-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1px; }
        .entry-title { font-family: 'Raleway', sans-serif; font-size: 9.5pt; font-weight: 700; color: #1a202c; }
        .entry-date { font-size: 7.5pt; color: #718096; font-weight: 600; white-space: nowrap; flex-shrink: 0; margin-left: 12px; }
        .entry-subtitle { font-size: 8.5pt; color: #4299e1; font-weight: 600; font-style: italic; margin-bottom: 3px; }
        .entry-desc { font-size: 8pt; color: #4a5568; line-height: 1.5; }
        .entry-desc ul { margin: 0; padding-left: 14px; }
        .entry-desc ul li { margin-bottom: 1.5px; }
        .entry-desc ul li::marker { color: #a0aec0; }

        .edu-entry { margin-bottom: 8px; page-break-inside: avoid; }
        .edu-entry .entry-header { margin-bottom: 0; }
        .edu-subtitle-line { font-size: 8pt; color: #718096; font-style: italic; }
    </style>
</head>

<body>
    <div class="cv-container">
        <!-- SIDEBAR -->
        <div class="sidebar">
            <div class="avatar">{{initials name}}</div>

            <div class="sidebar-section">
                <div class="sidebar-title">{{labels.contact}}</div>
                {{#if email}}
                <div class="contact-item"><i class="fa-solid fa-envelope"></i><a href="mailto:{{email}}">{{email}}</a></div>
                {{/if}}
                {{#if phone}}
                <div class="contact-item"><i class="fa-solid fa-phone"></i><span>{{phone}}</span></div>
                {{/if}}
                {{#if address}}
                <div class="contact-item"><i class="fa-solid fa-location-dot"></i><span>{{address}}</span></div>
                {{/if}}
                {{#if birthDate}}
                <div class="contact-item"><i class="fa-solid fa-calendar-days"></i><span>{{birthDate}}</span></div>
                {{/if}}
                {{#if linkedin}}
                <div class="contact-item"><i class="fa-brands fa-linkedin"></i><a href="{{formatLink linkedin 'linkedin'}}" target="_blank">{{linkedin}}</a></div>
                {{/if}}
                {{#if github}}
                <div class="contact-item"><i class="fa-brands fa-github"></i><a href="{{formatLink github 'github'}}" target="_blank">{{github}}</a></div>
                {{/if}}
                {{#if portfolio}}
                <div class="contact-item"><i class="fa-solid fa-globe"></i><a href="{{formatLink portfolio 'url'}}" target="_blank">{{portfolio}}</a></div>
                {{/if}}
            </div>

            {{#if skills.length}}
            <div class="sidebar-section">
                <div class="sidebar-title">{{labels.skills}}</div>
                <div class="skill-tags">
                    {{#each skills}}
                    <span class="skill-tag">{{this.title}}</span>
                    {{/each}}
                </div>
            </div>
            {{/if}}

            {{#if languages.length}}
            <div class="sidebar-section">
                <div class="sidebar-title">{{labels.languages}}</div>
                {{#each languages}}
                <div class="lang-item">
                    <span class="lang-name">{{this.title}}</span>
                    <span class="lang-level">{{this.description}}</span>
                </div>
                {{/each}}
            </div>
            {{/if}}

            {{#if certificates.length}}
            <div class="sidebar-section">
                <div class="sidebar-title">{{labels.certificates}}</div>
                {{#each certificates}}
                <div class="cert-item">
                    <div class="cert-name">{{this.title}}</div>
                    {{#if this.description}}<div class="cert-desc">{{this.description}}</div>{{/if}}
                </div>
                {{/each}}
            </div>
            {{/if}}
        </div>

        <!-- MAIN CONTENT -->
        <div class="main-content">
            <div class="main-name">{{name}}</div>
            {{#if summary}}
            <div class="main-subtitle">{{labels.profile}}</div>
            <div class="summary-text">{{summary}}</div>
            {{/if}}

            {{#if experiences.length}}
            <div class="section-heading">
                <div class="icon-circle"><i class="fa-solid fa-briefcase"></i></div>
                <h2>{{labels.experience}}</h2>
            </div>
            {{#each experiences}}
            <div class="entry">
                <div class="entry-header">
                    <span class="entry-title">{{this.title}}</span>
                    <span class="entry-date">{{this.startDate}} – {{#if this.endDate}}{{this.endDate}}{{else}}{{../labels.present}}{{/if}}</span>
                </div>
                {{#if this.subtitle}}<div class="entry-subtitle">{{this.subtitle}}</div>{{/if}}
                {{#if this.description}}
                <div class="entry-desc">{{bulletPoints this.description}}</div>
                {{/if}}
            </div>
            {{/each}}
            {{/if}}

            {{#if educations.length}}
            <div class="section-heading">
                <div class="icon-circle"><i class="fa-solid fa-graduation-cap"></i></div>
                <h2>{{labels.education}}</h2>
            </div>
            {{#each educations}}
            <div class="edu-entry">
                <div class="entry-header">
                    <span class="entry-title">{{this.title}}</span>
                    <span class="entry-date">{{this.startDate}} – {{#if this.endDate}}{{this.endDate}}{{else}}{{../labels.present}}{{/if}}</span>
                </div>
                {{#if this.subtitle}}<div class="edu-subtitle-line">{{this.subtitle}}</div>{{/if}}
                {{#if this.description}}
                <div class="entry-desc">{{bulletPoints this.description}}</div>
                {{/if}}
            </div>
            {{/each}}
            {{/if}}

            {{#if projects.length}}
            <div class="section-heading">
                <div class="icon-circle"><i class="fa-solid fa-diagram-project"></i></div>
                <h2>{{labels.projects}}</h2>
            </div>
            {{#each projects}}
            <div class="entry">
                <div class="entry-header">
                    <span class="entry-title">{{this.title}}</span>
                    <span class="entry-date">{{#if this.startDate}}{{this.startDate}}{{/if}}{{#if this.endDate}} – {{this.endDate}}{{/if}}</span>
                </div>
                {{#if this.subtitle}}<div class="entry-subtitle">{{this.subtitle}}</div>{{/if}}
                {{#if this.description}}
                <div class="entry-desc">{{bulletPoints this.description}}</div>
                {{/if}}
            </div>
            {{/each}}
            {{/if}}
        </div>
    </div>
</body>

</html>